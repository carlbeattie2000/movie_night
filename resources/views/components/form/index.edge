@let(formProps = $props.get('route') ? formAttributes(
  $props.get('route'),
  $props.get('routeParams'),
  $props.get('routeOptions'),
) : {
  method: $props.get('method'),
  action: $props.get('action')
})
<form {{ $props
  .except(['action', 'method', 'route', 'routeParams', 'routeOptions'])
  .merge(formProps)
  .toAttrs() }}
>
  {{{ await $slots.main() }}}
</form>
