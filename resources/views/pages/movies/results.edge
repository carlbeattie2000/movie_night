@layout()
  <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-3 p-4">
    @each(movie in results)
      @!component('components/movie', {
                  title: movie.title,
                  release_date: movie.release_date,
                  poster_path: movie.poster_path,
                  vote_average: movie.vote_average.toFixed(1),
                  id: movie.id,
                  add_button: true
      })
    @end
  </div>
@end
